generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  name                String
  avatarUrl           String?  @map("avatar_url")
  googleRefreshToken  String?  @map("google_refresh_token")
  createdAt           DateTime @default(now()) @map("created_at")

  familyMemberships      FamilyMember[]
  createdEvents          Event[]            @relation("EventCreator")
  createdMeals           Meal[]             @relation("MealCreator")
  createdChores          Chore[]            @relation("ChoreCreator")
  assignedChores         Chore[]            @relation("ChoreAssignee")
  choreCompletions       ChoreCompletion[]  @relation("CompletionCompleter")
  choreVerifications     ChoreCompletion[]  @relation("CompletionVerifier")
  checkedGroceryItems    GroceryItem[]      @relation("GroceryChecker")
  createdSharedLists     SharedList[]       @relation("SharedListCreator")
  createdSharedListItems SharedListItem[]   @relation("SharedListItemCreator")
  createdRewards         Reward[]           @relation("RewardCreator")
  redemptions            Redemption[]       @relation("RedemptionRedeemer")
  approvedRedemptions    Redemption[]       @relation("RedemptionApprover")
  pushSubscriptions      PushSubscription[]

  @@map("users")
}

model Family {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique @map("invite_code")
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now()) @map("created_at")

  members      FamilyMember[]
  events       Event[]
  meals        Meal[]
  groceryItems GroceryItem[]
  chores       Chore[]
  sharedLists  SharedList[]
  rewards      Reward[]

  @@map("families")
}

model FamilyMember {
  familyId String   @map("family_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([familyId, userId])
  @@map("family_members")
}

model Event {
  id             String   @id @default(uuid())
  familyId       String   @map("family_id")
  title          String
  description    String?
  startTime      DateTime @map("start_time")
  endTime        DateTime @map("end_time")
  allDay         Boolean  @default(false) @map("all_day")
  recurrenceRule String?  @map("recurrence_rule")
  googleEventId  String?  @unique @map("google_event_id")
  color          String   @default("blue")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  family  Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  creator User   @relation("EventCreator", fields: [createdBy], references: [id])

  @@index([familyId])
  @@index([startTime])
  @@map("events")
}

model Meal {
  id        String   @id @default(uuid())
  familyId  String   @map("family_id")
  name      String
  date      String
  mealType  String   @map("meal_type")
  recipeUrl String?  @map("recipe_url")
  notes     String?
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  family       Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  creator      User             @relation("MealCreator", fields: [createdBy], references: [id])
  ingredients  MealIngredient[]
  groceryItems GroceryItem[]

  @@index([familyId, date])
  @@map("meals")
}

model MealIngredient {
  id       String @id @default(uuid())
  mealId   String @map("meal_id")
  name     String
  quantity String?
  category String @default("Other")

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("meal_ingredients")
}

model GroceryItem {
  id           String   @id @default(uuid())
  familyId     String   @map("family_id")
  name         String
  quantity     String?
  category     String   @default("Other")
  sourceMealId String?  @map("source_meal_id")
  checked      Boolean  @default(false)
  checkedBy    String?  @map("checked_by")
  createdAt    DateTime @default(now()) @map("created_at")

  family     Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sourceMeal Meal?  @relation(fields: [sourceMealId], references: [id], onDelete: SetNull)
  checker    User?  @relation("GroceryChecker", fields: [checkedBy], references: [id])

  @@index([familyId])
  @@map("grocery_items")
}

model Chore {
  id             String   @id @default(uuid())
  familyId       String   @map("family_id")
  title          String
  description    String?
  assignedTo     String?  @map("assigned_to")
  recurrenceRule String?  @map("recurrence_rule")
  points         Int      @default(1)
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  family      Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  creator     User              @relation("ChoreCreator", fields: [createdBy], references: [id])
  assignee    User?             @relation("ChoreAssignee", fields: [assignedTo], references: [id])
  completions ChoreCompletion[]

  @@index([familyId])
  @@map("chores")
}

model ChoreCompletion {
  id          String   @id @default(uuid())
  choreId     String   @map("chore_id")
  completedBy String   @map("completed_by")
  completedAt DateTime @default(now()) @map("completed_at")
  verifiedBy  String?  @map("verified_by")

  chore     Chore @relation(fields: [choreId], references: [id], onDelete: Cascade)
  completer User  @relation("CompletionCompleter", fields: [completedBy], references: [id])
  verifier  User? @relation("CompletionVerifier", fields: [verifiedBy], references: [id])

  @@index([choreId])
  @@map("chore_completions")
}

model SharedList {
  id        String   @id @default(uuid())
  familyId  String   @map("family_id")
  name      String
  template  String?
  archived  Boolean  @default(false)
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  family  Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  creator User             @relation("SharedListCreator", fields: [createdBy], references: [id])
  items   SharedListItem[]

  @@index([familyId])
  @@map("shared_lists")
}

model SharedListItem {
  id        String   @id @default(uuid())
  listId    String   @map("list_id")
  name      String
  checked   Boolean  @default(false)
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  list    SharedList @relation(fields: [listId], references: [id], onDelete: Cascade)
  creator User       @relation("SharedListItemCreator", fields: [createdBy], references: [id])

  @@index([listId])
  @@map("shared_list_items")
}

model Reward {
  id          String   @id @default(uuid())
  familyId    String   @map("family_id")
  name        String
  description String?
  pointsCost  Int      @map("points_cost")
  active      Boolean  @default(true)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  family      Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  creator     User         @relation("RewardCreator", fields: [createdBy], references: [id])
  redemptions Redemption[]

  @@index([familyId])
  @@map("rewards")
}

model Redemption {
  id         String    @id @default(uuid())
  rewardId   String    @map("reward_id")
  redeemedBy String    @map("redeemed_by")
  status     String    @default("pending")
  approvedBy String?   @map("approved_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  redeemer User   @relation("RedemptionRedeemer", fields: [redeemedBy], references: [id])
  approver User?  @relation("RedemptionApprover", fields: [approvedBy], references: [id])

  @@index([rewardId])
  @@map("redemptions")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreference {
  userId           String  @id @map("user_id")
  eventReminders   Boolean @default(true) @map("event_reminders")
  choreAssignments Boolean @default(true) @map("chore_assignments")
  morningDigest    Boolean @default(true) @map("morning_digest")
  rewardApprovals  Boolean @default(true) @map("reward_approvals")

  @@map("notification_preferences")
}

model FamilyPreferences {
  familyId            String  @id @map("family_id")
  dietaryRestrictions String? @map("dietary_restrictions")
  cuisinePreferences  String? @map("cuisine_preferences")
  householdSize       Int?    @map("household_size")

  @@map("family_preferences")
}
